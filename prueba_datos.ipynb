   "source": [
    "#Se clasifican en temáticas los proyectos de acuerdo a palabras clave que identifican cada uno\n",
    "def categorizar_proyecto(texto):\n",
    "    texto = str(texto).lower()\n",
    "    \n",
    "    if any(w in texto for w in ['escuela', 'jardín', 'colegio', 'secundaria', 'primaria', 'estudiantil', 'educación', 'educacion', 'aula', 'pizarrón', 'escuelita', 'educativo']):\n",
    "        return 'Educación'\n",
    "    \n",
    "    elif any(w in texto for w in ['cámara', 'seguridad', 'patrullero', 'iluminación', 'luces', 'alarma', 'camara', 'iluminacion', 'tótem', 'vigilancia', 'punto seguro']):\n",
    "        return 'Seguridad'\n",
    "    \n",
    "    elif any(w in texto for w in ['salud', 'hospital', 'unidad de respuesta', 'salita', 'maternal', 'ambulatoria', 'vacunatorio', 'médico', 'medico', 'ambulancia', 'emergencia', 'emergencias']):\n",
    "        return 'Salud'\n",
    "    \n",
    "    elif any(w in texto for w in ['deporte', 'club', 'gimnasio', 'playón', 'cancha', 'playon', 'polideportivo', 'entrenamiento']):\n",
    "        return 'Deporte'\n",
    "    \n",
    "    elif any(w in texto for w in ['cultura', 'teatro', 'museo', 'centro cultural', 'biblioteca', 'talleres', 'música', 'danza', 'Club', 'orquesta', 'turismo']):\n",
    "        return 'Cultura'\n",
    "\n",
